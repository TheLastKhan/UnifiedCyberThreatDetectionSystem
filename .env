# ========================================
# UNIFIED CYBER THREAT DETECTION SYSTEM
# Environment Configuration
# ========================================

# ========================================
# Flask Configuration
# ========================================
FLASK_ENV=production
FLASK_APP=web_dashboard/app.py
DEBUG=False
SECRET_KEY=dev-secret-key-32-chars-minimum-here-123456

# ========================================
# Server Configuration
# ========================================
HOST=0.0.0.0
PORT=5000
WORKERS=4
WORKER_CLASS=sync
TIMEOUT=120

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://threat_user:threat_password@db:5432/threat_detection
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=False

# ========================================
# Redis Configuration (Optional)
# ========================================
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_URL=redis://cache:6379/0
REDIS_TIMEOUT=10
REDIS_SOCKET_CONNECT_TIMEOUT=10
REDIS_SOCKET_KEEPALIVE=True

# ========================================
# Model Configuration
# ========================================
MODEL_PATH=models
MAX_EMAIL_LENGTH=50000
MAX_LOGS_BATCH=10000
MODEL_CACHE_TTL=3600
FEATURE_CACHE_TTL=1800

# ========================================
# Security API Keys
# ========================================
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
VIRUSTOTAL_REQUESTS_PER_MINUTE=4

# ========================================
# Kaggle Configuration
# ========================================
KAGGLE_API_TOKEN=KGAT_2a591641b7ba07fff72536e07a5329d5
KAGGLE_USERNAME=your_kaggle_username

# ========================================
# Email Configuration (for alerts)
# ========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_RECIPIENTS=admin@example.com

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ========================================
# Feature Flags
# ========================================
ENABLE_VIRUSTOTAL_INTEGRATION=True
ENABLE_CORRELATION_ANALYSIS=True
ENABLE_DARK_MODE=True
ENABLE_I18N=True
ENABLE_BERT_DETECTION=True
